# ─────────────────────────────────────────────────────────────────
# .env.example — 환경 변수 템플릿
# 이 파일을 복사해서 .env로 만들고, 실제 값을 채워 넣으세요.
#   cp .env.example .env
#
# ⚠️  .env 파일은 절대 Git에 커밋하지 마세요 (.gitignore에 등록됨)
# ─────────────────────────────────────────────────────────────────

# ── Bybit API 키 (거래 실행에 필요) ──────────────────────────────
# Bybit 계정 → API Management → Create New Key 에서 발급
# 권한: "Read" + "Trade" (Unified Trading 계정)
# Paper trading(--mode paper)만 사용한다면 비워도 됩니다.
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here

# Bybit Testnet 사용 시 (선택)
# BYBIT_TESTNET=true

# ── Google Gemini API 키 (TUI AI 어시스턴트 기능, 선택) ──────────
# https://aistudio.google.com/app/apikey 에서 무료 발급
# 없으면 TUI AI 패널만 비활성화되고 나머지 기능은 정상 동작합니다.
GEMINI_API_KEY=your_gemini_api_key_here
# GOOGLE_API_KEY=your_google_api_key_here   # 위 키가 없을 때 대체 사용

# ── 선택적 설정 ──────────────────────────────────────────────────
# 로그 레벨: DEBUG / INFO / WARNING / ERROR (기본: INFO)
# LOG_LEVEL=INFO

# 기본 심볼 (쉼표 구분, 기본: BTCUSDT)
# SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT

# 기본 타임프레임 (기본: 1h)
# TIMEFRAME=1h
